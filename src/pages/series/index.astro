---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const seriesEntries = await getCollection('series', ({ data }) => data.published);
const allPhotos     = await getCollection('photos', ({ data }) => data.status === 'published');

// Pour chaque série : compte les photos + fallback cover sur la 1re photo publiée
const cards = seriesEntries
  .map((s) => {
    const photos = allPhotos
      .filter((p) => p.data.series === s.data.slug)
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

    const cover =
      s.data.cover_url ||
      photos[0]?.data.url_thumb ||
      photos[0]?.data.url ||
      '';

    return {
      slug:        s.data.slug,
      name:        s.data.name,
      description: s.data.description,
      cover,
      count: photos.length,
      tags:  s.data.tags ?? [],
    };
  })
  .filter((c) => c.count > 0)
  .sort((a, b) => b.count - a.count);
---

<Base title="Séries | Portfolio" description="Toutes les séries photo">

  <section class="page-header reveal">
    <h1>Séries</h1>
    <p>{cards.length} série{cards.length > 1 ? 's' : ''} · {cards.reduce((n, c) => n + c.count, 0)} photographies</p>
  </section>

  {cards.length === 0 ? (
    <p class="empty">Aucune série publiée pour l'instant.</p>
  ) : (
    <div class="series-grid">
      {cards.map((s) => (
        <a href={`/series/${s.slug}/`} class="s-card reveal">
          <div class="s-img-wrap">
            {s.cover
              ? <img src={s.cover} alt={s.name} loading="lazy" />
              : <div class="s-placeholder" aria-hidden="true" />}
            <div class="s-overlay">
              <span class="s-cta">Voir la série →</span>
            </div>
          </div>
          <div class="s-body">
            <h2>{s.name}</h2>
            {s.description && <p>{s.description}</p>}
            <div class="s-footer">
              <span class="s-count">{s.count} photo{s.count > 1 ? 's' : ''}</span>
              {s.tags.length > 0 && (
                <div class="s-tags">
                  {s.tags.slice(0, 3).map((t) => <span>#{t}</span>)}
                </div>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>
  )}

</Base>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .page-header p {
    margin: 0.3rem 0 0;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--muted);
    letter-spacing: 0.03em;
  }

  .empty {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    padding: 3rem 0;
  }

  /* ── Grid ───────────────────────────────────────────── */
  .series-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  /* ── Card ───────────────────────────────────────────── */
  .s-card {
    display: flex;
    flex-direction: column;
    background: linear-gradient(155deg, rgba(14, 30, 62, 0.9), rgba(8, 18, 40, 0.9));
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 220ms ease, transform 220ms ease;
  }

  .s-card:hover {
    border-color: rgba(116, 143, 255, 0.35);
    transform: translateY(-3px);
  }

  /* ── Image ──────────────────────────────────────────── */
  .s-img-wrap {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--surface);
  }

  .s-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 380ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .s-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(36, 58, 101, 0.4), rgba(15, 31, 61, 0.6));
  }

  .s-overlay {
    position: absolute;
    inset: 0;
    background: rgba(5, 11, 26, 0.45);
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    padding: 0.85rem;
    opacity: 0;
    transition: opacity 240ms ease;
  }

  .s-card:hover .s-overlay { opacity: 1; }
  .s-card:hover .s-img-wrap img { transform: scale(1.05); }

  .s-cta {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: #fff;
    background: rgba(116, 143, 255, 0.25);
    border: 1px solid rgba(116, 143, 255, 0.4);
    border-radius: 999px;
    padding: 0.3rem 0.8rem;
    backdrop-filter: blur(6px);
  }

  /* ── Body ───────────────────────────────────────────── */
  .s-body {
    padding: 1rem 1.1rem 1.1rem;
    display: grid;
    gap: 0.45rem;
    flex: 1;
  }

  .s-body h2 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--text);
    margin: 0;
    line-height: 1.2;
  }

  .s-body p {
    margin: 0;
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .s-footer {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-top: 0.2rem;
  }

  .s-count {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .s-tags {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }

  .s-tags span {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: rgba(159, 178, 212, 0.65);
    background: rgba(116, 143, 255, 0.08);
    border-radius: 999px;
    padding: 0.1rem 0.45rem;
  }

  @media (max-width: 640px) {
    .series-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
