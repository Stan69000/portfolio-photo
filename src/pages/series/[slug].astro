---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Lightbox from '../../components/Lightbox.astro';

export async function getStaticPaths() {
  const seriesEntries = await getCollection('series', ({ data }) => data.published);
  return seriesEntries.map((series) => ({
    params: { slug: series.data.slug },
    props: { series }
  }));
}

const { series } = Astro.props;
const photos = (await getCollection('photos'))
  .filter((photo) => photo.data.series === series.data.slug && photo.data.status === 'published')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((photo) => ({
    id: photo.id,
    slug: photo.data.slug,
    title: photo.data.title,
    description: photo.data.description,
    url: photo.data.url,
    tags: photo.data.tags ?? []
  }));

const allTags = (series.data.tags ?? []).slice(0, 10);
const hero = photos[0];
const siteBase = Astro.site ?? new URL('https://stan-bouchet.eu');
const canonicalPath = `/series/${series.data.slug}/`;
const pageUrl = new URL(canonicalPath, siteBase).toString();
const pageImage = hero?.url || series.data.cover_url || '';

const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: series.data.name,
  description: series.data.description,
  url: pageUrl,
  ...(pageImage ? { image: pageImage } : {})
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: new URL('/', siteBase).toString() },
    { '@type': 'ListItem', position: 2, name: 'Séries', item: new URL('/series/', siteBase).toString() },
    { '@type': 'ListItem', position: 3, name: series.data.name, item: pageUrl }
  ]
};

---

<Base
  title={`${series.data.name} | Portfolio`}
  description={series.data.description}
  image={pageImage}
  type="article"
  canonicalPath={canonicalPath}
  jsonLd={[collectionJsonLd, breadcrumbJsonLd]}
>
  <section class="hero reveal">
    {hero && (
      <button
        type="button"
        class="hero-image"
        data-lightbox-index="0"
        aria-label={`Ouvrir ${hero.title} en plein écran`}
      >
        <img src={hero.url} alt={hero.title} loading="eager" decoding="async" style={`view-transition-name: photo-${hero.slug};`} />
      </button>
    )}
    <div class="hero-copy">
      <a href="/series" class="back">← Toutes les séries</a>
      <h1>{series.data.name}</h1>
      <p>{series.data.description}</p>
      <div class="series-stats">
        <span>{photos.length} photographie{photos.length > 1 ? 's' : ''}</span>
      </div>
      {allTags.length > 0 && (
        <div class="tags">
          {allTags.map((tag) => (
            <span>#{tag}</span>
          ))}
        </div>
      )}

      {(series.data.map_lat && series.data.map_lng) || ((series.data.links ?? []).length > 0) ? (
        <div class="extras-grid">
          {series.data.map_lat && series.data.map_lng && (
            <div class="map-inline">
              <p class="extras-label">📍 Secteur</p>
              <div id="series-map" class="series-map"></div>
            </div>
          )}
          {(series.data.links ?? []).length > 0 && (
            <div class="links-inline">
              <p class="extras-label">🔗 Liens utiles</p>
              <div class="links-col">
                {(series.data.links ?? []).map((link) => (
                  <a href={link.url} target="_blank" rel="noopener noreferrer" class="ext-link">
                    {link.label}
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      ) : null}

    </div>
  </section>

  {series.data.map_lat && series.data.map_lng && (
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script define:vars={{ lat: series.data.map_lat, lng: series.data.map_lng, zoom: series.data.map_zoom ?? 13, name: series.data.map_label || series.data.name }}>
      (function() {
        function initMap() {
          if (!window.L || !document.getElementById('series-map')) return;
          const map = L.map('series-map', { zoomControl: true, scrollWheelZoom: false, attributionControl: true }).setView([lat, lng], zoom);
          L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
            attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> © <a href="https://carto.com/">CARTO</a>',
            maxZoom: 19,
          }).addTo(map);
          const icon = L.divIcon({
            className: '',
            html: '<div style="width:14px;height:14px;background:#748fff;border:2px solid #fff;border-radius:50%;box-shadow:0 0 8px rgba(116,143,255,.7)"></div>',
            iconSize: [14, 14],
            iconAnchor: [7, 7],
          });
          L.marker([lat, lng], { icon }).addTo(map).bindPopup(`<strong>${name}</strong>`).openPopup();
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initMap);
        } else {
          initMap();
        }
      })();
    </script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  )}

  <section class="mosaic">
    {photos.map((photo, index) => (
      <button
        type="button"
        class={`tile ${index % 7 === 0 ? 'large' : ''} reveal`}
        data-lightbox-index={index}
        aria-label={`Ouvrir ${photo.title} en plein écran`}
        style={`animation-delay: ${Math.min(index * 40, 400)}ms`}
      >
        <img src={photo.url} alt={photo.title} loading="lazy" decoding="async" style={`view-transition-name: photo-${photo.slug};`} />
        <div class="caption">
          <strong>{photo.title}</strong>
          {photo.description && <span>{photo.description}</span>}
        </div>
      </button>
    ))}
  </section>

  <Lightbox photos={photos} />
</Base>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
    align-items: stretch;
  }

  .hero-image {
    display: block;
    width: 100%;
    min-height: 300px;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--line);
    padding: 0;
    background: var(--surface);
    cursor: zoom-in;
    position: relative;
  }

  .hero-image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
    transition: transform 400ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .hero-image:hover img {
    transform: scale(1.03);
  }

  .hero-copy {
    background: linear-gradient(150deg, rgba(15, 33, 67, 0.95), rgba(8, 19, 41, 0.95));
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.4rem;
    display: grid;
    align-content: start;
    gap: 0.85rem;
  }

  .back {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
    transition: color 180ms ease;
  }

  .back:hover {
    color: var(--text);
  }

  .hero-copy h1 {
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
  }

  .hero-copy p {
    margin: 0;
  }

  .series-stats {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .tags span {
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    padding: 0.2rem 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: #c9dbff;
  }

  .mosaic {
    columns: 3;
    column-gap: 1rem;
  }

  .tile {
    break-inside: avoid;
    position: relative;
    border-radius: 0.8rem;
    overflow: hidden;
    border: 1px solid var(--line);
    display: block;
    padding: 0;
    background: var(--surface);
    cursor: zoom-in;
    margin-bottom: 1rem;
    width: 100%;
  }

  .tile.large {
    /* intentionnellement identique en masonry — la hauteur naturelle suffit */
  }

  .tile img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 320ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .tile::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.04) 35%, rgba(0, 0, 0, 0.76) 100%);
    z-index: 1;
    opacity: 0;
    transition: opacity 280ms ease;
  }

  .tile:hover::before {
    opacity: 1;
  }

  .caption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    padding: 0.85rem;
    display: grid;
    gap: 0.2rem;
    transform: translateY(6px);
    opacity: 0;
    transition: transform 280ms cubic-bezier(0.4, 0, 0.2, 1), opacity 280ms ease;
  }

  .tile:hover .caption {
    transform: translateY(0);
    opacity: 1;
  }

  .tile:hover img {
    transform: scale(1.04);
  }

  .caption strong {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 400;
    color: #eef5ff;
  }

  .caption span {
    font-size: 0.82rem;
    color: rgba(197, 215, 251, 0.9);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 980px) {
    .hero {
      grid-template-columns: 1fr;
    }

    .hero-image {
      min-height: 300px;
    }

    .mosaic {
      columns: 2;
    }
  }

  @media (max-width: 520px) {
    .mosaic {
      columns: 1;
    }
  }

  /* ── Extras inline dans hero-copy ── */
  .extras-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    margin: 0 0 0.5rem;
  }

  /* Map + Links side by side */
  .extras-grid {
    border-top: 1px solid var(--line);
    padding-top: 0.85rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    align-items: start;
  }

  .map-inline,
  .links-inline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .series-map {
    aspect-ratio: 1;
    width: 100%;
    border-radius: calc(var(--radius) - 4px);
    overflow: hidden;
    border: 1px solid var(--line);
  }

  /* Override Leaflet popup */
  :global(.leaflet-popup-content-wrapper) {
    background: #fff;
    color: #1a2a4a;
    border: 1px solid #d0d8e8;
    border-radius: 8px;
    box-shadow: 0 4px 16px rgba(0,0,0,.18);
  }
  :global(.leaflet-popup-tip) { background: #fff; }
  :global(.leaflet-popup-close-button) { color: #748fff !important; }

  /* Links */
  .links-col {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .ext-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text);
    background: rgba(116, 143, 255, 0.08);
    border: 1px solid rgba(116, 143, 255, 0.25);
    border-radius: 8px;
    padding: 0.45rem 0.8rem;
    transition: background 180ms ease, border-color 180ms ease, color 180ms ease;
    text-decoration: none;
  }

  .ext-link:hover {
    background: rgba(116, 143, 255, 0.18);
    border-color: var(--accent);
    color: var(--accent);
  }

  .ext-link svg {
    opacity: 0.6;
    flex-shrink: 0;
  }
</style>
