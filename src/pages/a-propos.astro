---
import { getEntry } from 'astro:content';
import Base from '../layouts/Base.astro';

const entry = await getEntry('pages', 'about');
if (!entry) return Astro.redirect('/');
const { Content } = await entry.render();
---

<Base title={`${entry.data.title} | Portfolio`} description={entry.data.description}>
  <article class="about-page reveal">
    <Content />
  </article>
</Base>

<style>
  .about-page {
    max-width: 68ch;
    margin: 0 auto;
  }

  .about-page :global(h1) {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 400;
    margin: 0 0 2rem;
  }

  .about-page :global(h2) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    margin: 2.5rem 0 0.75rem;
    color: var(--text);
  }

  .about-page :global(p) {
    font-size: 1rem;
    line-height: 1.75;
    margin: 0 0 1rem;
    color: var(--muted);
  }

  .about-page :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .about-page :global(a) {
    color: var(--accent);
    border-bottom: 1px solid rgba(116, 143, 255, 0.3);
    transition: border-color 180ms ease;
  }

  .about-page :global(a:hover) {
    border-bottom-color: var(--accent);
  }

  .about-page :global(ul), .about-page :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1rem;
    color: var(--muted);
    line-height: 1.75;
  }

  .about-page :global(hr) {
    border: none;
    border-top: 1px solid var(--line);
    margin: 2.5rem 0;
  }

  .about-page :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--muted);
  }

  .about-page :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: rgba(116, 143, 255, 0.1);
    border: 1px solid rgba(116, 143, 255, 0.2);
    border-radius: 4px;
    padding: 0.1em 0.4em;
  }
</style>
