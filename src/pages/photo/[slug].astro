---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const photos = (await getCollection('photos')).filter((p) => p.data.status === 'published');
  const sorted = photos.sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0));
  const seriesCollection = await getCollection('series');
  const seriesTagsBySlug = new Map(seriesCollection.map((s) => [s.data.slug, s.data.tags ?? []]));
  const seriesDateBySlug = new Map(seriesCollection.map((s) => [s.data.slug, s.data.date ?? null]));
  return sorted.map((photo, index) => ({
    params: { slug: photo.data.slug },
    props: {
      photo,
      seriesTags: seriesTagsBySlug.get(photo.data.series) ?? [],
      seriesDate: seriesDateBySlug.get(photo.data.series) ?? null,
      prev: sorted[index - 1] ?? null,
      next: sorted[index + 1] ?? null
    }
  }));
}

const { photo, seriesTags, seriesDate, prev, next } = Astro.props;
const effectiveDate: Date | null = photo.data.date ?? (seriesDate ? new Date(seriesDate) : null);
const locationVisibility = photo.data.location?.public_visibility ?? 'hidden';
const locationIsPublic = locationVisibility === 'approx' || locationVisibility === 'precise';
const locationDisplay =
  (locationIsPublic && (photo.data.location?.label || photo.data.location?.address))
    ? (photo.data.location?.label || photo.data.location?.address || '')
    : '';
const siteBase = Astro.site ?? new URL('https://stan-bouchet.eu');
const canonicalPath = `/photo/${photo.data.slug}/`;
const photoUrl = new URL(canonicalPath, siteBase).toString();
const seriesPath = photo.data.series ? `/series/${photo.data.series}/` : '';
const seriesUrl = seriesPath ? new URL(seriesPath, siteBase).toString() : '';
const pageImage = photo.data.url_web || photo.data.url || '';

const exif = photo.data.exif;
const exifFields = exif
  ? [
      exif.camera && { label: 'Boîtier', value: exif.camera },
      exif.lens   && { label: 'Objectif', value: exif.lens },
      exif.focal_length && { label: 'Focale', value: exif.focal_length },
      exif.settings && { label: 'Réglages', value: exif.settings },
      exif.iso    && { label: 'ISO', value: String(exif.iso) }
    ].filter(Boolean)
  : [];

const effectiveTags = [...new Set([...seriesTags, ...(photo.data.tags ?? [])])];
const tagGroups: Record<string, string[]> = {};
for (const tag of effectiveTags) {
  const i = tag.indexOf(':');
  const cat = i > 0 ? tag.slice(0, i).trim() : '';
  const val = i > 0 ? tag.slice(i + 1).trim() : tag;
  if (!tagGroups[cat]) tagGroups[cat] = [];
  tagGroups[cat].push(val);
}

const allSeries = await getCollection('series', ({ data }) => data.status === 'published' || data.published);
const seriesBySlug = new Map(allSeries.map((s) => [s.data.slug, s.data.name]));
const seriesName = seriesBySlug.get(photo.data.series) ?? photo.data.series.replace(/-/g, ' ');

const allPublished = (await getCollection('photos'))
  .filter((p) => p.data.status === 'published' && p.data.slug !== photo.data.slug)
  .map((p) => {
    const tags = new Set(p.data.tags ?? []);
    const sharedTags = effectiveTags.filter((t) => tags.has(t)).length;
    const sameSeries = p.data.series === photo.data.series;
    const score = (sameSeries ? 5 : 0) + sharedTags * 2;
    return {
      slug: p.data.slug,
      title: p.data.title,
      series: p.data.series,
      seriesName: seriesBySlug.get(p.data.series) ?? p.data.series.replace(/-/g, ' '),
      url: p.data.url_thumb || p.data.url,
      urlLarge: p.data.url_web || p.data.url,
      score,
      date: p.data.date?.getTime() ?? 0
    };
  });

const relatedPhotos = allPublished
  .filter((p) => p.score > 0)
  .sort((a, b) => b.score - a.score || b.date - a.date)
  .slice(0, 6);


const imageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ImageObject',
  name: photo.data.title,
  description: photo.data.description || photo.data.title,
  contentUrl: pageImage,
  url: photoUrl,
  ...(effectiveDate ? { datePublished: effectiveDate.toISOString() } : {}),
  ...(photo.data.exif?.camera ? { model: photo.data.exif.camera } : {}),
  ...(effectiveTags.length > 0 ? { keywords: effectiveTags.join(', ') } : {})
};

const breadcrumbItems = [
  { '@type': 'ListItem', position: 1, name: 'Accueil', item: new URL('/', siteBase).toString() },
  { '@type': 'ListItem', position: 2, name: 'Photos', item: new URL('/photos/', siteBase).toString() }
];

if (seriesUrl) {
  breadcrumbItems.push({
    '@type': 'ListItem',
    position: breadcrumbItems.length + 1,
    name: seriesName,
    item: seriesUrl
  });
}

breadcrumbItems.push({
  '@type': 'ListItem',
  position: breadcrumbItems.length + 1,
  name: photo.data.title,
  item: photoUrl
});

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems
};
---

<Base
  title={`${photo.data.title} | Portfolio`}
  description={photo.data.description || photo.data.title}
  image={pageImage}
  type="article"
  canonicalPath={canonicalPath}
  jsonLd={[imageJsonLd, breadcrumbJsonLd]}
>
  <article class="photo-detail">

    <div class="image-frame">
      <img
        src={photo.data.url}
        alt={photo.data.title}
        loading="eager"
        decoding="async"
        style={`view-transition-name: photo-${photo.data.slug};`}
      />
    </div>

    <div class="detail-body">

      <nav class="breadcrumb">
        <a href="/photos">← Photos</a>
        {photo.data.series && (
          <>
            <span>·</span>
            <a href={`/series/${photo.data.series}/`}>{photo.data.series.replace(/-/g, ' ')}</a>
          </>
        )}
      </nav>

      <header class="detail-header">
        <h1>{photo.data.title}</h1>
        {photo.data.description && <p class="description">{photo.data.description}</p>}
      </header>

      <div class="actions-row">
        <div class="star-widget-wrap">
          <div data-star-widget={photo.data.slug}>
            {[1,2,3,4,5].map(n => (
              <button class="star-btn" data-star={n} data-star-slug={photo.data.slug} aria-label={`${n} étoile${n > 1 ? 's' : ''}`} title={`${n} étoile${n > 1 ? 's' : ''}`}>★</button>
            ))}
          </div>
          <span class="star-label"></span>
        </div>
        <div class="share-group">
          <button type="button" class="share-btn" id="share-copy-btn">Copier le lien</button>
          <button type="button" class="share-btn" id="share-native-btn">Partager</button>
        </div>
        {photo.data.for_sale && (
          <span class="for-sale">
            {photo.data.price ? `${photo.data.price} € — tirage` : 'Tirage sur demande'}
          </span>
        )}
      </div>

      <div class="meta-grid">
        {effectiveDate && (
          <div class="meta-item">
            <span class="meta-label">Date du reportage</span>
            <span class="meta-value">{effectiveDate.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          </div>
        )}
        {photo.data.series && (
          <div class="meta-item">
            <span class="meta-label">Série</span>
            <a href={`/series/${photo.data.series}/`} class="meta-value meta-link">
              {seriesName}
            </a>
          </div>
        )}
        {locationDisplay && (
          <div class="meta-item">
            <span class="meta-label">Lieu</span>
            <span class="meta-value">
              {locationDisplay}
              {locationVisibility === 'approx' && ' (approximatif)'}
            </span>
          </div>
        )}
      </div>

      {effectiveTags.length > 0 && (
        <div class="tags-section">
          {Object.entries(tagGroups).map(([cat, vals]) => (
            <div class="tag-group">
              {cat && <span class="tag-cat">{cat}</span>}
              <div class="tags-row">
                {vals.map((val) => {
                  const full = cat ? `${cat}:${val}` : val;
                  return <a href={`/recherche?tag=${encodeURIComponent(full)}`} class="tag">#{val}</a>;
                })}
              </div>
            </div>
          ))}
        </div>
      )}

      {exifFields.length > 0 && (
        <div class="exif-block">
          <p class="exif-heading">Données EXIF</p>
          <dl class="exif-grid">
            {exifFields.map((field) => (
              <>
                <dt>{field.label}</dt>
                <dd>{field.value}</dd>
              </>
            ))}
          </dl>
        </div>
      )}

    </div>

    {relatedPhotos.length > 0 && (
      <section class="related-photos">
        <header class="related-head">
          <h2>Photos similaires</h2>
          <p>Même univers de série ou tags proches.</p>
        </header>
        <div class="related-grid">
          {relatedPhotos.map((item) => (
            <a href={`/photo/${item.slug}/`} class="related-card">
              <img src={item.url} alt={item.title} loading="lazy" decoding="async" />
              <div class="related-body">
                <strong>{item.title}</strong>
                <span>{item.seriesName}</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <nav class="photo-nav">
      {prev ? (
        <a href={`/photo/${prev.data.slug}/`} class="photo-nav-item photo-nav-prev">
          <img src={prev.data.url_thumb || prev.data.url} alt={prev.data.title} loading="lazy" decoding="async" />
          <div class="photo-nav-label">
            <span>← Précédente</span>
            <strong>{prev.data.title}</strong>
          </div>
        </a>
      ) : <span />}
      {next ? (
        <a href={`/photo/${next.data.slug}/`} class="photo-nav-item photo-nav-next">
          <div class="photo-nav-label photo-nav-label--right">
            <span>Suivante →</span>
            <strong>{next.data.title}</strong>
          </div>
          <img src={next.data.url_thumb || next.data.url} alt={next.data.title} loading="lazy" decoding="async" />
        </a>
      ) : <span />}
    </nav>

  </article>
</Base>

<style>
  .photo-detail {
    display: grid;
    gap: 2rem;
  }

  /* Image */
  .image-frame {
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface);
    border: 1px solid var(--line);
    max-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .image-frame img {
    width: 100%;
    max-height: 80vh;
    object-fit: contain;
    display: block;
  }

  /* Body */
  .detail-body {
    display: grid;
    gap: 1.4rem;
    max-width: 68ch;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
  }

  .breadcrumb span {
    opacity: 0.5;
  }

  .breadcrumb a:hover {
    color: var(--text);
  }

  .detail-header {
    display: grid;
    gap: 0.6rem;
  }

  .detail-header h1 {
    font-size: clamp(1.8rem, 4vw, 3rem);
  }

  .description {
    margin: 0;
    font-size: 1rem;
    line-height: 1.65;
  }

  /* Actions */
  .actions-row {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .vote-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border: 1px solid var(--line);
    background: rgba(116, 143, 255, 0.08);
    color: var(--text);
    border-radius: 999px;
    padding: 0.45rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    cursor: pointer;
    transition: background 200ms ease, border-color 200ms ease;
  }

  .vote-btn:hover {
    background: rgba(116, 143, 255, 0.2);
    border-color: var(--accent);
  }

  .vote-btn:disabled {
    opacity: 0.55;
    cursor: default;
  }

  .vote-display {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--muted);
  }

  .for-sale {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
    border: 1px solid rgba(116, 143, 255, 0.35);
    border-radius: 999px;
    padding: 0.3rem 0.75rem;
  }

  .share-group {
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .share-btn {
    border: 1px solid var(--line);
    background: rgba(15, 31, 61, 0.3);
    color: var(--muted);
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    cursor: pointer;
    transition: color 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .share-btn:hover {
    color: var(--text);
    border-color: rgba(116, 143, 255, 0.35);
    background: rgba(116, 143, 255, 0.1);
  }

  /* Meta grid */
  .meta-grid {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .meta-item {
    display: grid;
    gap: 0.2rem;
  }

  .meta-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }

  .meta-value {
    font-size: 0.95rem;
    color: var(--text);
  }

  .meta-link:hover {
    color: var(--accent);
  }

  /* Tags */
  .tags-section {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .tag-group {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag-cat {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    background: rgba(116, 143, 255, 0.1);
    border: 1px solid rgba(116, 143, 255, 0.25);
    border-radius: 999px;
    padding: 0.15rem 0.55rem;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .tags-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.22rem 0.65rem;
    transition: color 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .tag:hover {
    color: var(--accent);
    border-color: rgba(116, 143, 255, 0.4);
    background: rgba(116, 143, 255, 0.07);
  }

  /* EXIF */
  .exif-block {
    background: rgba(15, 31, 61, 0.6);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1rem 1.2rem;
  }

  .exif-heading {
    margin: 0 0 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
  }

  .exif-grid {
    margin: 0;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.3rem 1.2rem;
  }

  .exif-grid dt {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
    white-space: nowrap;
  }

  .exif-grid dd {
    margin: 0;
    font-size: 0.88rem;
    color: var(--text);
  }

  .related-photos {
    display: grid;
    gap: 0.8rem;
    border-top: 1px solid var(--line);
    padding-top: 1rem;
  }

  .related-head {
    display: grid;
    gap: 0.2rem;
  }

  .related-head h2 {
    font-size: 1.35rem;
  }

  .related-head p {
    margin: 0;
    font-size: 0.85rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .related-card {
    border: 1px solid var(--line);
    border-radius: 0.75rem;
    overflow: hidden;
    background: rgba(15, 31, 61, 0.4);
    transition: border-color 180ms ease, transform 180ms ease;
  }

  .related-card:hover {
    border-color: rgba(116, 143, 255, 0.4);
    transform: translateY(-2px);
  }

  .related-card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  .related-body {
    display: grid;
    gap: 0.15rem;
    padding: 0.6rem 0.7rem 0.75rem;
  }

  .related-body strong {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.2;
  }

  .related-body span {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.03em;
  }

  /* Prev / Next navigation */
  .photo-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }

  .photo-nav-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem;
    border-radius: var(--radius);
    border: 1px solid var(--line);
    background: rgba(15, 31, 61, 0.4);
    transition: background 200ms ease, border-color 200ms ease;
    overflow: hidden;
  }

  .photo-nav-item:hover {
    background: rgba(36, 58, 101, 0.5);
    border-color: rgba(116, 143, 255, 0.3);
  }

  .photo-nav-item img {
    width: 56px;
    height: 42px;
    object-fit: cover;
    border-radius: 0.4rem;
    flex-shrink: 0;
  }

  .photo-nav-label {
    display: grid;
    gap: 0.15rem;
  }

  .photo-nav-label--right {
    text-align: right;
    justify-items: end;
  }

  .photo-nav-label span {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .photo-nav-label strong {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 20ch;
  }

  .photo-nav-next {
    flex-direction: row-reverse;
  }

  @media (max-width: 680px) {
    .related-grid {
      grid-template-columns: 1fr;
    }

    .photo-nav {
      grid-template-columns: 1fr;
    }
  }
</style>

<script
  is:inline
  define:vars={{
    slug: photo.data.slug,
    title: photo.data.title,
    thumb: photo.data.url_thumb || photo.data.url
  }}
>
  const RECENT_KEY = 'stan-photo-recent-v1';

  try {
    const currentUrl = `${location.origin}/photo/${slug}/`;
    const parsed = JSON.parse(localStorage.getItem(RECENT_KEY) || '[]');
    const list = Array.isArray(parsed) ? parsed : [];
    const updated = [
      { slug, title, thumb, url: currentUrl, viewedAt: Date.now() },
      ...list.filter((item) => item?.slug !== slug)
    ].slice(0, 15);
    localStorage.setItem(RECENT_KEY, JSON.stringify(updated));
  } catch {}

  const copyBtn = document.getElementById('share-copy-btn');
  const nativeBtn = document.getElementById('share-native-btn');

  copyBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(location.href);
      copyBtn.textContent = 'Lien copié';
      setTimeout(() => { copyBtn.textContent = 'Copier le lien'; }, 1400);
    } catch {
      copyBtn.textContent = 'Impossible';
      setTimeout(() => { copyBtn.textContent = 'Copier le lien'; }, 1400);
    }
  });

  nativeBtn?.addEventListener('click', async () => {
    if (!navigator.share) return;
    try {
      await navigator.share({ title, text: title, url: location.href });
    } catch {}
  });

  if (!navigator.share && nativeBtn) {
    nativeBtn.style.display = 'none';
  }
</script>
