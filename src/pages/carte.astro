---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

type MarkerPhoto = {
  kind: 'series' | 'photo';
  slug: string;
  title: string;
  href: string;
  seriesSlug: string;
  seriesName: string;
  date: string;
  thumb: string;
};

type Marker = {
  lat: number;
  lng: number;
  visibility: 'approx' | 'precise';
  sourceType: 'series' | 'photo';
  count: number;
  label: string;
  entries: MarkerPhoto[];
  seriesSlugs: string[];
};

const publishedPhotos = await getCollection('photos', ({ data }) => data.status === 'published');
const publishedSeries = await getCollection('series', ({ data }) => data.published);
const seriesNameBySlug = new Map(publishedSeries.map((s) => [s.data.slug, s.data.name]));
const seriesPhotosMap = new Map<string, typeof publishedPhotos>();
for (const photo of publishedPhotos) {
  const slug = photo.data.series || '';
  if (!slug) continue;
  if (!seriesPhotosMap.has(slug)) seriesPhotosMap.set(slug, []);
  seriesPhotosMap.get(slug)!.push(photo);
}

function asNumber(value: unknown): number | null {
  const n = Number(value);
  if (!Number.isFinite(n)) return null;
  return n;
}

function toDisplayCoord(value: number, visibility: 'approx' | 'precise'): number {
  if (visibility === 'precise') return Number(value.toFixed(6));
  return Number(value.toFixed(2));
}

const grouped = new Map<string, Marker>();

function upsertMarker(
  lat: number,
  lng: number,
  visibility: 'approx' | 'precise',
  sourceType: 'series' | 'photo',
  label: string,
  entry: MarkerPhoto,
  countWeight: number
) {
  const displayLat = toDisplayCoord(lat, visibility);
  const displayLng = toDisplayCoord(lng, visibility);
  const key = `${displayLat}|${displayLng}|${visibility}`;
  const existing = grouped.get(key);
  if (existing) {
    existing.count += Math.max(1, countWeight);
    if (existing.entries.length < 10) existing.entries.push(entry);
    if (entry.seriesSlug && !existing.seriesSlugs.includes(entry.seriesSlug)) existing.seriesSlugs.push(entry.seriesSlug);
    return;
  }
  grouped.set(key, {
      lat: displayLat,
      lng: displayLng,
      visibility,
      sourceType,
      count: Math.max(1, countWeight),
      label,
      entries: [entry],
      seriesSlugs: entry.seriesSlug ? [entry.seriesSlug] : []
    });
}

for (const serie of publishedSeries) {
  const visibilityRaw = serie.data.map_public_visibility ?? 'precise';
  const visibility = visibilityRaw === 'approx' ? 'approx' : visibilityRaw === 'precise' ? 'precise' : 'hidden';
  if (visibility === 'hidden') continue;
  const lat = asNumber(serie.data.map_lat);
  const lng = asNumber(serie.data.map_lng);
  if (lat === null || lng === null) continue;
  if (lat < -90 || lat > 90 || lng < -180 || lng > 180) continue;
  const photos = (seriesPhotosMap.get(serie.data.slug) ?? [])
    .slice()
    .sort((a, b) => (b.data.date?.getTime?.() ?? 0) - (a.data.date?.getTime?.() ?? 0));
  const cover = serie.data.cover_url || photos[0]?.data.url_thumb || photos[0]?.data.url_web || photos[0]?.data.url || '';
  const photoCount = Math.max(1, photos.length);
  upsertMarker(
    lat,
    lng,
    visibility,
    'series',
    serie.data.map_label || serie.data.map_address || serie.data.name,
    {
      kind: 'series',
      slug: serie.data.slug,
      title: serie.data.name,
      href: `/series/${serie.data.slug}/`,
      seriesSlug: serie.data.slug,
      seriesName: serie.data.name,
      date: serie.data.date || '',
      thumb: cover
    },
    photoCount
  );
}

for (const photo of publishedPhotos) {
  const location = photo.data.location;
  if (!location) continue;
  const visibility = location.public_visibility;
  if (visibility !== 'approx' && visibility !== 'precise') continue;
  const lat = asNumber(location.lat);
  const lng = asNumber(location.lng);
  if (lat === null || lng === null) continue;
  if (lat < -90 || lat > 90 || lng < -180 || lng > 180) continue;

  const label = location.label || location.address || (seriesNameBySlug.get(photo.data.series) ?? photo.data.series.replace(/-/g, ' '));
  const photoItem: MarkerPhoto = {
    kind: 'photo',
    slug: photo.data.slug,
    title: photo.data.title,
    href: `/photo/${photo.data.slug}/`,
    seriesSlug: photo.data.series,
    seriesName: seriesNameBySlug.get(photo.data.series) ?? photo.data.series.replace(/-/g, ' '),
    date: photo.data.date ? photo.data.date.toISOString().slice(0, 10) : '',
    thumb: photo.data.url_thumb || photo.data.url_web || photo.data.url
  };
  upsertMarker(lat, lng, visibility, 'photo', label, photoItem, 1);
}

const markers = [...grouped.values()].sort((a, b) => b.count - a.count);
const totalPhotosMapped = markers.reduce((acc, item) => acc + item.count, 0);
const markerCount = markers.length;
const preciseCount = markers.filter((m) => m.visibility === 'precise').length;
const approxCount = markers.filter((m) => m.visibility === 'approx').length;
---

<Base title="Carte des prises de vue | Portfolio" description="Visualiser les lieux des photos en France et dans le monde.">
  <section class="map-hero reveal">
    <div class="map-copy">
      <p class="kicker">Atlas photo</p>
      <h1>Où les images ont été prises</h1>
      <p>
        Partez à la découverte des lieux capturés à travers ces images.
        Parfois très précis, parfois plus approximatifs, ces repères vous aident à replacer chaque photo dans son environnement.
        Peut-être y trouverez-vous une idée de balade… ou simplement une nouvelle façon de regarder ces endroits.
      </p>
      <div class="stats">
        <span>{totalPhotosMapped} photo{totalPhotosMapped > 1 ? 's' : ''} localisée{totalPhotosMapped > 1 ? 's' : ''}</span>
        <span>{markerCount} lieu{markerCount > 1 ? 'x' : ''}</span>
        <span>{preciseCount} précis · {approxCount} approximatif{approxCount > 1 ? 's' : ''}</span>
      </div>
      <div class="actions">
        <button type="button" class="mode-btn active" id="mode-fr">France</button>
        <button type="button" class="mode-btn" id="mode-world">Monde</button>
      </div>
    </div>
    <div class="legend">
      <h2>Légende</h2>
      <div class="legend-grid">
        <div class="legend-group">
          <h3>Type de localisation</h3>
          <div class="legend-item"><span class="dot series"></span>Localisation série</div>
          <div class="legend-note">Point principal d’un reportage ou d’une série complète.</div>
          <div class="legend-item"><span class="dot photo"></span>Localisation photo</div>
          <div class="legend-note">Point spécifique défini directement sur une image.</div>
        </div>
        <div class="legend-group">
          <h3>Niveau de précision</h3>
          <div class="legend-item"><span class="dot precise"></span>Position précise</div>
          <div class="legend-item"><span class="dot approx"></span>Position approximative</div>
          <div class="legend-note">La couleur indique la précision. Le contour indique s’il s’agit d’une série ou d’une photo.</div>
        </div>
      </div>
    </div>
  </section>

  <section class="map-shell">
    <div id="photo-map" class="photo-map" aria-label="Carte des lieux de prise de vue"></div>
  </section>

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css" />
  <script define:vars={{ markers }}>
    (function () {
      const mapEl = document.getElementById('photo-map');
      if (!mapEl) return;

      function loadScript(src) {
        return new Promise((resolve, reject) => {
          const existing = document.querySelector(`script[data-src="${src}"]`);
          if (existing) {
            if (existing.dataset.loaded === '1') resolve();
            else existing.addEventListener('load', () => resolve(), { once: true });
            return;
          }
          const script = document.createElement('script');
          script.src = src;
          script.async = false;
          script.dataset.src = src;
          script.addEventListener('load', () => {
            script.dataset.loaded = '1';
            resolve();
          }, { once: true });
          script.addEventListener('error', () => reject(new Error(`Échec chargement ${src}`)), { once: true });
          document.head.appendChild(script);
        });
      }

      async function loadFromCdn(urls, isReady) {
        let lastError = null;
        for (const url of urls) {
          try {
            await loadScript(url);
            if (isReady()) return;
          } catch (err) {
            lastError = err;
          }
        }
        throw lastError || new Error('Ressource indisponible');
      }

      async function initMap() {
        await loadFromCdn(
          [
            'https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js',
            'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js'
          ],
          () => Boolean(window.L && typeof window.L.map === 'function')
        );
        if (!window.L) throw new Error('Leaflet indisponible');

        const frBounds = L.latLngBounds([41.2, -5.2], [51.2, 9.7]);
        const worldBounds = L.latLngBounds([-62, -178], [82, 178]);

        const map = L.map('photo-map', { zoomControl: true, minZoom: 2 }).setView([46.2276, 2.2137], 5);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
          maxZoom: 19,
          attribution: '© OpenStreetMap © CARTO',
        }).addTo(map);

        const markerLayer = L.layerGroup();
        const markerRefs = [];

        function esc(str) {
          return String(str || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
        }

        function buildPopup(point) {
          const preview = point.entries
            .map((item) => {
              const when = item.date ? new Date(item.date).toLocaleDateString('fr-FR') : '';
              return (
                '<a class="popup-item" href="' + esc(item.href) + '">' +
                  (item.thumb ? '<img src="' + esc(item.thumb) + '" alt="' + esc(item.title) + '" loading="lazy">' : '<div class="popup-fallback"></div>') +
                  '<div class="popup-body">' +
                    '<strong>' + esc(item.title) + '</strong>' +
                    '<span>' + esc(item.seriesName) + (when ? ' · ' + esc(when) : '') + '</span>' +
                  '</div>' +
                '</a>'
              );
            })
            .join('');

          const note = point.visibility === 'approx'
            ? '<p class="popup-note">Position volontairement approximative.</p>'
            : '';

          return (
            '<div class="popup-wrap">' +
              '<h3>' + esc(point.label) + '</h3>' +
              '<p class="popup-count">' + point.count + ' photo' + (point.count > 1 ? 's' : '') + '</p>' +
              note +
              '<div class="popup-list">' + preview + '</div>' +
            '</div>'
          );
        }

        markers.forEach((point) => {
          const color = point.visibility === 'approx' ? '#e9a756' : '#4f7dff';
          const sourceWeight = point.sourceType === 'series' ? 3 : 2.4;
          const sourceFillOpacity = point.sourceType === 'series' ? 0.98 : 0.82;
          const sourceStroke = point.sourceType === 'series' ? '#ffffff' : '#6de2cb';
          const actionUrl = point.seriesSlugs.length === 1
            ? '/recherche?series=' + encodeURIComponent(point.seriesSlugs[0])
            : '/recherche?q=' + encodeURIComponent(point.label);
          const marker = L.circleMarker([point.lat, point.lng], {
            radius: point.sourceType === 'series' ? 9 : 7,
            color: sourceStroke,
            weight: sourceWeight,
            fillColor: color,
            fillOpacity: sourceFillOpacity
          });
          if (point.sourceType === 'photo') {
            marker.setStyle({ dashArray: '2 2' });
          }
          marker.bindPopup(buildPopup(point), { maxWidth: 440, minWidth: 290, closeButton: true });
          marker.bindTooltip(
            '<a class="map-hover-link" href="' + actionUrl + '">' +
              '<strong>' + esc(point.label) + '</strong>' +
              '<em>' + (point.sourceType === 'series' ? 'Localisation série' : 'Localisation photo') + '</em>' +
              '<span>Voir ' + point.count + ' photo' + (point.count > 1 ? 's' : '') + '</span>' +
            '</a>',
            { direction: 'top', offset: [0, -12], opacity: 0.95, sticky: true }
          );
          markerLayer.addLayer(marker);
          markerRefs.push({ point, marker });
        });

        map.addLayer(markerLayer);
        map.fitBounds(frBounds.pad(0.02));
        function forceRender() {
          map.invalidateSize(true);
          map.panBy([0, 0], { animate: false });
        }
        requestAnimationFrame(forceRender);
        setTimeout(forceRender, 40);
        setTimeout(forceRender, 140);
        setTimeout(forceRender, 420);
        map.whenReady(forceRender);
        map.on('load', forceRender);
        map.on('zoomend', forceRender);
        window.addEventListener('resize', forceRender);

        const frBtn = document.getElementById('mode-fr');
        const worldBtn = document.getElementById('mode-world');
        function setMode(mode) {
          if (mode === 'world') {
            map.setMaxBounds(null);
            map.setMinZoom(2);
            map.fitBounds(worldBounds);
            worldBtn?.classList.add('active');
            frBtn?.classList.remove('active');
            return;
          }
          map.setMaxBounds(frBounds.pad(0.12));
          map.setMinZoom(5);
          map.fitBounds(frBounds.pad(0.02));
          frBtn?.classList.add('active');
          worldBtn?.classList.remove('active');
        }
        frBtn?.addEventListener('click', () => setMode('fr'));
        worldBtn?.addEventListener('click', () => setMode('world'));
        setMode('fr');

        const params = new URLSearchParams(window.location.search);
        const focusLat = Number(params.get('lat'));
        const focusLng = Number(params.get('lng'));
        if (Number.isFinite(focusLat) && Number.isFinite(focusLng)) {
          const focusZoom = 11;
          map.setView([focusLat, focusLng], focusZoom, { animate: false });
          let best = null;
          let bestDist = Infinity;
          for (const ref of markerRefs) {
            const dLat = ref.point.lat - focusLat;
            const dLng = ref.point.lng - focusLng;
            const dist = (dLat * dLat) + (dLng * dLng);
            if (dist < bestDist) {
              bestDist = dist;
              best = ref.marker;
            }
          }
          if (best) {
            setTimeout(() => {
              best.openPopup();
            }, 120);
          }
        }
      }

      initMap().catch(() => {
        mapEl.innerHTML = '<div style="padding:1rem;color:#9fb2d4;font-family:var(--font-mono);font-size:.8rem">Impossible de charger la carte (ressources externes bloquées).</div>';
      });
    })();
  </script>
</Base>

<style>
  .map-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, .8fr);
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .map-copy {
    background: linear-gradient(148deg, rgba(18, 37, 74, 0.92), rgba(8, 18, 42, 0.95));
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.2rem;
    display: grid;
    gap: .8rem;
  }

  .kicker {
    margin: 0;
    font-family: var(--font-mono);
    font-size: .76rem;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #c0d4ff;
  }

  .map-copy h1 {
    font-size: clamp(1.8rem, 4.2vw, 3rem);
  }

  .map-copy p {
    margin: 0;
  }

  .stats {
    display: flex;
    gap: .45rem;
    flex-wrap: wrap;
  }

  .stats span {
    border: 1px solid rgba(116, 143, 255, 0.28);
    background: rgba(116, 143, 255, 0.12);
    border-radius: 999px;
    padding: .2rem .62rem;
    font-family: var(--font-mono);
    font-size: .72rem;
    color: #d2e0ff;
  }

  .actions {
    display: flex;
    gap: .55rem;
    flex-wrap: wrap;
  }

  .mode-btn {
    border: 1px solid rgba(116, 143, 255, 0.35);
    background: rgba(8, 19, 41, 0.6);
    color: var(--muted);
    border-radius: 999px;
    padding: .34rem .82rem;
    font-family: var(--font-mono);
    font-size: .74rem;
    cursor: pointer;
    transition: all .2s ease;
  }

  .mode-btn:hover,
  .mode-btn.active {
    border-color: var(--accent);
    color: var(--text);
    background: rgba(116, 143, 255, 0.15);
  }

  .legend {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1rem;
    background: linear-gradient(145deg, rgba(14, 30, 62, .82), rgba(7, 16, 37, .88));
    display: grid;
    align-content: start;
    gap: .55rem;
  }

  .legend h2 {
    margin: 0;
    font-size: 1.15rem;
  }

  .legend-grid {
    display: grid;
    grid-template-columns: 1.1fr .9fr;
    gap: 1rem;
    align-items: start;
  }

  .legend-group {
    display: grid;
    gap: .45rem;
    align-content: start;
  }

  .legend-group h3 {
    margin: 0;
    font-size: .78rem;
    font-family: var(--font-mono);
    letter-spacing: .06em;
    text-transform: uppercase;
    color: #8ea5d8;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: .45rem;
    font-size: .88rem;
    color: #d8e4ff;
  }

  .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    display: inline-block;
    border: 1px solid rgba(255, 255, 255, .45);
  }

  .dot.precise { background: #4f7dff; }
  .dot.approx { background: #e9a756; }
  .dot.series { background: #4f7dff; border-width: 2px; border-color: #ffffff; }
  .dot.photo { background: #4f7dff; border-style: dashed; border-width: 2px; border-color: #6de2cb; opacity: .86; }

  .legend-note {
    margin: 0 0 .25rem 1.55rem;
    font-size: .76rem;
    color: var(--muted);
    line-height: 1.45;
  }

  .map-shell {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    background: rgba(7, 16, 37, 0.9);
  }

  .photo-map {
    width: 100%;
    height: min(74vh, 760px);
    min-height: 420px;
  }

  :global(.map-pin) {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: block;
    border: 2px solid #fff;
    box-shadow: 0 0 12px rgba(0, 0, 0, 0.35);
  }

  :global(.pin-precise) {
    background: #4f7dff;
  }

  :global(.pin-approx) {
    background: #e9a756;
  }

  :global(.popup-wrap h3) {
    margin: 0;
    font-size: 1.02rem;
    color: #13284f;
  }

  :global(.popup-count) {
    margin: .15rem 0 .45rem;
    font-size: .74rem;
    font-family: var(--font-mono);
    color: #516792;
  }

  :global(.popup-note) {
    margin: 0 0 .45rem;
    font-size: .72rem;
    color: #9f611d;
  }

  :global(.popup-list) {
    display: grid;
    gap: .45rem;
    max-height: 255px;
    overflow: auto;
    padding-right: .15rem;
  }

  :global(.popup-item) {
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: .5rem;
    align-items: center;
    border: 1px solid #dde7f7;
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
  }

  :global(.popup-item img) {
    width: 88px;
    height: 62px;
    object-fit: cover;
    display: block;
  }

  :global(.popup-fallback) {
    width: 88px;
    height: 62px;
    background: linear-gradient(135deg, #d7e2f7, #eff4ff);
    border-right: 1px solid #e5edfb;
  }

  :global(.popup-body) {
    display: grid;
    gap: .15rem;
    padding-right: .5rem;
  }

  :global(.popup-body strong) {
    font-size: .92rem;
    color: #152a50;
    line-height: 1.15;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  :global(.popup-body span) {
    font-size: .72rem;
    color: #6b7ea5;
    font-family: var(--font-mono);
    line-height: 1.2;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  :global(.leaflet-tooltip) {
    background: rgba(9, 21, 46, 0.92);
    border: 1px solid rgba(116, 143, 255, 0.5);
    color: #dce8ff;
    border-radius: 999px;
    padding: .25rem .55rem;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.28);
  }

  :global(.leaflet-tooltip:before) {
    border-top-color: rgba(116, 143, 255, 0.5) !important;
  }

  :global(.map-hover-link) {
    display: grid;
    gap: .1rem;
    color: #dce8ff;
    text-decoration: none;
  }

  :global(.map-hover-link strong) {
    font-family: var(--font-display);
    font-size: .92rem;
    font-weight: 600;
    line-height: 1.05;
    max-width: 240px;
  }

  :global(.map-hover-link em) {
    font-style: normal;
    font-family: var(--font-mono);
    font-size: .64rem;
    letter-spacing: .05em;
    text-transform: uppercase;
    color: #93b1f4;
  }

  :global(.map-hover-link span) {
    font-family: var(--font-mono);
    font-size: .68rem;
    letter-spacing: .04em;
    text-transform: uppercase;
    color: #bfd3ff;
  }

  @media (max-width: 900px) {
    .map-hero {
      grid-template-columns: 1fr;
    }

    .legend-grid {
      grid-template-columns: 1fr;
      gap: .75rem;
    }
  }
</style>
