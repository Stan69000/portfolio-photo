---
import { getCollection } from 'astro:content';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  canonicalPath?: string;
}

const {
  title = 'Portfolio Photo',
  description = 'Portfolio photo personnel',
  image = '',
  type = 'website',
  noindex = false,
  jsonLd,
  canonicalPath
} = Astro.props;

const { pathname } = Astro.url;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);

const settingsEntries = await getCollection('settings');
const wordmark = settingsEntries[0]?.data?.site_title || 'Stan';
const baseSiteUrl = Astro.site ?? new URL('https://stan-bouchet.eu');
const canonicalUrl = new URL(canonicalPath ?? pathname, baseSiteUrl).toString();
const ogImage = image
  ? (image.startsWith('http://') || image.startsWith('https://')
    ? image
    : new URL(image, baseSiteUrl).toString())
  : '';
const jsonLdList = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex,nofollow' : 'index,follow'} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:site_name" content={wordmark} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=IBM+Plex+Sans:wght@300;400;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <script type="module" src="/scripts/votes.js"></script>
    <link rel="alternate" type="application/rss+xml" title="Stan Bouchet — Photographie" href="/rss.xml" />
    {jsonLdList.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="wordmark">{wordmark}</a>

        <!-- Desktop nav -->
        <nav class="nav" id="main-nav" aria-label="Navigation principale">
          <a href="/" class:list={['nav-link', { active: isActive('/') }]}>Accueil</a>
          <a href="/photos" class:list={['nav-link', { active: isActive('/photos') || isActive('/photo') }]}>Photos</a>
          <a href="/series" class:list={['nav-link', { active: isActive('/series') }]}>Séries</a>
          <a href="/recherche" class:list={['nav-link nav-search', { active: isActive('/recherche') }]} aria-label="Recherche">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <span>Recherche</span>
          </a>
          <a href="/stats" class:list={['nav-link', { active: isActive('/stats') }]}>Favoris</a>
          <a href="/a-propos" class:list={['nav-link', { active: isActive('/a-propos') }]}>À propos</a>
          <a href="/rss.xml" class="nav-rss" aria-label="Flux RSS" title="S'abonner au flux RSS" target="_blank" rel="noopener noreferrer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
          </a>
        </nav>

        <!-- Hamburger button (mobile only) -->
        <button class="burger" id="burger-btn" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu">
          <span></span><span></span><span></span>
        </button>
      </div>

      <!-- Mobile menu -->
      <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
        <a href="/" class:list={['mobile-link', { active: isActive('/') }]}>Accueil</a>
        <a href="/photos" class:list={['mobile-link', { active: isActive('/photos') || isActive('/photo') }]}>Photos</a>
        <a href="/series" class:list={['mobile-link', { active: isActive('/series') }]}>Séries</a>
        <a href="/recherche" class:list={['mobile-link', { active: isActive('/recherche') }]}>Recherche</a>
        <a href="/stats" class:list={['mobile-link', { active: isActive('/stats') }]}>Favoris</a>
        <a href="/a-propos" class:list={['mobile-link', { active: isActive('/a-propos') }]}>À propos</a>
        <a href="/rss.xml" class="mobile-link mobile-rss" target="_blank" rel="noopener noreferrer">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
          RSS
        </a>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Site réalisé avec <span class="heart">❤️</span> par <a href="https://www.linkedin.com/in/stanislas-bouchet/" target="_blank" rel="noopener noreferrer">Stan BOUCHET</a></p>
      <p class="footer-license">
        © Stan Bouchet – Tous droits réservés.<br />
        Les contenus de ce site sont protégés par la licence
        <a href="https://creativecommons.org/licenses/by-nc-nd/4.0/" target="_blank" rel="noopener noreferrer">CC BY-NC-ND 4.0</a>
        — Attribution, Pas d'Utilisation Commerciale, Pas de Modification.
      </p>
    </footer>
  </body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(18px) saturate(1.4);
    -webkit-backdrop-filter: blur(18px) saturate(1.4);
    background: rgba(5, 11, 26, 0.72);
    border-bottom: 1px solid rgba(36, 58, 101, 0.5);
  }

  .header-inner {
    max-width: var(--max);
    margin: 0 auto;
    padding: 0.9rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .wordmark {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 400;
    letter-spacing: 0.06em;
    color: var(--text);
  }

  .nav {
    display: flex;
    gap: 0.25rem;
    align-items: center;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: var(--muted);
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    border: 1px solid transparent;
    transition: color 200ms ease, border-color 200ms ease, background 200ms ease;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--text);
    border-color: var(--line);
    background: rgba(36, 58, 101, 0.3);
  }

  .nav-link.active {
    color: var(--text);
    border-color: var(--line);
    background: rgba(116, 143, 255, 0.12);
  }

  .nav-search {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .nav-rss {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #f26522;
    opacity: 0.75;
    padding: 0.35rem 0.4rem;
    border-radius: 999px;
    border: 1px solid transparent;
    transition: opacity 200ms ease, border-color 200ms ease, background 200ms ease;
  }

  .nav-rss:hover {
    opacity: 1;
    border-color: rgba(242, 101, 34, 0.4);
    background: rgba(242, 101, 34, 0.1);
  }

  /* ── Hamburger button ───────────────────────────────────── */
  .burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    padding: 6px;
    background: none;
    border: 1px solid var(--line);
    border-radius: 0.5rem;
    cursor: pointer;
    flex-shrink: 0;
  }

  .burger span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--muted);
    border-radius: 2px;
    transition: transform 220ms ease, opacity 220ms ease, background 220ms ease;
    transform-origin: center;
  }

  .burger[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .burger[aria-expanded="true"] span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .burger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  .burger[aria-expanded="true"] { border-color: var(--accent); }
  .burger[aria-expanded="true"] span { background: var(--accent); }

  /* ── Mobile menu panel ──────────────────────────────────── */
  .mobile-menu {
    display: none;
    flex-direction: column;
    padding: 0.5rem 1rem 1rem;
    border-top: 1px solid rgba(36, 58, 101, 0.4);
    gap: 0.15rem;
  }

  .mobile-menu.open {
    display: flex;
  }

  .mobile-link {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    letter-spacing: 0.03em;
    color: var(--muted);
    padding: 0.7rem 0.8rem;
    border-radius: 0.6rem;
    border: 1px solid transparent;
    transition: color 180ms ease, background 180ms ease, border-color 180ms ease;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .mobile-link:hover,
  .mobile-link.active {
    color: var(--text);
    background: rgba(116, 143, 255, 0.08);
    border-color: var(--line);
  }

  .mobile-link.active {
    background: rgba(116, 143, 255, 0.12);
  }

  .mobile-rss {
    color: #f26522;
  }

  @media (max-width: 700px) {
    .nav { display: none; }
    .burger { display: flex; }

    .header-inner {
      padding: 0.75rem 1rem;
    }

    .wordmark {
      font-size: 1.15rem;
    }
  }

  .site-footer {
    margin-top: 5rem;
    padding: 2rem 1.5rem;
    border-top: 1px solid var(--line);
    text-align: center;
  }

  .site-footer p {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
    letter-spacing: 0.03em;
  }

  .footer-license {
    margin-top: 0.6rem !important;
    font-size: 0.72rem !important;
    opacity: 0.7;
    line-height: 1.7;
  }

  .site-footer a {
    color: var(--muted);
    border-bottom: 1px solid transparent;
    transition: color 180ms ease, border-color 180ms ease;
  }

  .site-footer a:hover {
    color: var(--text);
    border-bottom-color: var(--muted);
  }

  .heart {
    font-style: normal;
  }
</style>

<script>
  // ── Hamburger menu ────────────────────────────────────────────────────────────
  function initBurger() {
    const btn = document.getElementById('burger-btn');
    const menu = document.getElementById('mobile-menu');
    if (!btn || !menu) return;

    btn.addEventListener('click', () => {
      const open = menu.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
      menu.setAttribute('aria-hidden', String(!open));
    });

    // Fermer le menu quand on clique sur un lien
    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
        menu.setAttribute('aria-hidden', 'true');
      });
    });
  }

  initBurger();
  document.addEventListener('astro:after-swap', initBurger);

  // Scroll-reveal via IntersectionObserver (progressive enhancement)
  document.documentElement.classList.add('js-ready');
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          (entry.target as HTMLElement).classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      }
    },
    { threshold: 0, rootMargin: '0px 0px -30px 0px' }
  );

  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>

<script is:inline>
  (function () {
    function protect(e) {
      const t = e.target;
      if (t.tagName === 'IMG' || t.closest('.photo-img-wrap, .card-img-btn, .detail-img-wrap, .hero-image')) {
        e.preventDefault();
        return false;
      }
    }
    document.addEventListener('contextmenu', protect);
    document.addEventListener('dragstart', protect);
  })();
</script>
