---
import { getCollection } from 'astro:content';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Portfolio Photo',
  description = 'Portfolio photo personnel'
} = Astro.props;

const { pathname } = Astro.url;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);

const settingsEntries = await getCollection('settings');
const wordmark = settingsEntries[0]?.data?.site_title || 'Stan';
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=IBM+Plex+Sans:wght@300;400;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <script type="module" src="/scripts/votes.js"></script>
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="wordmark">{wordmark}</a>
        <nav class="nav">
          <a href="/" class:list={['nav-link', { active: isActive('/') }]}>Accueil</a>
          <a href="/photos" class:list={['nav-link', { active: isActive('/photos') || isActive('/photo') }]}>Photos</a>
          <a href="/series" class:list={['nav-link', { active: isActive('/series') }]}>Séries</a>
          <a href="/recherche" class:list={['nav-link nav-search', { active: isActive('/recherche') }]} aria-label="Recherche">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <span>Recherche</span>
          </a>
          <a href="/stats" class:list={['nav-link', { active: isActive('/stats') }]}>Coups de cœur</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Site réalisé avec <span class="heart">❤️</span> par <a href="https://www.linkedin.com/in/stanislas-bouchet/" target="_blank" rel="noopener noreferrer">Stan BOUCHET</a></p>
    </footer>
  </body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(18px) saturate(1.4);
    -webkit-backdrop-filter: blur(18px) saturate(1.4);
    background: rgba(5, 11, 26, 0.72);
    border-bottom: 1px solid rgba(36, 58, 101, 0.5);
  }

  .header-inner {
    max-width: var(--max);
    margin: 0 auto;
    padding: 0.9rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .wordmark {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 400;
    letter-spacing: 0.06em;
    color: var(--text);
  }

  .nav {
    display: flex;
    gap: 0.25rem;
    align-items: center;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: var(--muted);
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    border: 1px solid transparent;
    transition: color 200ms ease, border-color 200ms ease, background 200ms ease;
  }

  .nav-link:hover {
    color: var(--text);
    border-color: var(--line);
    background: rgba(36, 58, 101, 0.3);
  }

  .nav-link.active {
    color: var(--text);
    border-color: var(--line);
    background: rgba(116, 143, 255, 0.12);
  }

  .nav-search {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  @media (max-width: 520px) {
    .nav-link {
      padding: 0.3rem 0.5rem;
      font-size: 0.78rem;
    }
  }

  .site-footer {
    margin-top: 5rem;
    padding: 2rem 1.5rem;
    border-top: 1px solid var(--line);
    text-align: center;
  }

  .site-footer p {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
    letter-spacing: 0.03em;
  }

  .site-footer a {
    color: var(--muted);
    border-bottom: 1px solid transparent;
    transition: color 180ms ease, border-color 180ms ease;
  }

  .site-footer a:hover {
    color: var(--text);
    border-bottom-color: var(--muted);
  }

  .heart {
    font-style: normal;
  }
</style>

<script>
  // Scroll-reveal via IntersectionObserver (progressive enhancement)
  document.documentElement.classList.add('js-ready');
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          (entry.target as HTMLElement).classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      }
    },
    { threshold: 0, rootMargin: '0px 0px -30px 0px' }
  );

  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
